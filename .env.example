# =================================================================
# A股自选股智能分析系统 - 环境变量模板
# =================================================================
# 配置指引：
# 1. 业务参数 (如并发数、语言) ➜ 见 settings.yaml
# 2. 股票列表 (如代码、分组) ➜ 见 stocks.yaml
# 3. AI 模型路由 (如多 Key 轮询) ➜ 见 litellm_config.yaml
# =================================================================

# === 1. 核心敏感 Token (必填项，至少一个 LLM Key) ===
GEMINI_API_KEY=your_gemini_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here
TUSHARE_TOKEN=your_tushare_token_here

# === 2. 搜索引擎 API Keys (选填，用于联网增强) ===
# Tavily（推荐）：https://app.tavily.com
TAVILY_API_KEY=
# AkShare 东方财富新闻源（无需配置，项目中已依赖）
# OpenBB 公司新闻源（可选；需本地安装 openbb 及对应 provider 扩展）
OPENBB_NEWS_ENABLED=false
OPENBB_NEWS_PROVIDER=yfinance

# === 2b. LLM 模型配置（选填，详见 litellm_config.yaml） ===
LITELLM_MODEL=gemini/gemini-2.0-flash-exp
LITELLM_FALLBACK_MODELS=
LITELLM_CONFIG=
# LLM_CHANNELS 用于多 Key 轮询 / 多供应商路由
# LLM_CHANNELS=

# === 2c. Agent 分析（选填） ===
# AGENT_MODE=true 会强制单股分析和策略问股走 Agent
AGENT_MODE=false
# 条件式过 Agent：经典单股分析仍是默认，但在数据缺口、密集/高风险情报等复杂场景自动升级为 Agent
AGENT_AUTO_ROUTE_ANALYSIS=false
# Agent 专用主模型（留空继承 LITELLM_MODEL）
AGENT_LITELLM_MODEL=
# Agent 架构：single / orchestrator
# AGENT_ARCH=single
# Agent Orchestrator 模式：standard / plan_then_exec
# AGENT_ORCHESTRATOR_MODE=standard
# Agent Orchestrator 超时（秒）
# AGENT_ORCHESTRATOR_TIMEOUT_S=600
# Agent 最大执行步数
# AGENT_MAX_STEPS=10
# Agent 技能列表（逗号分隔）
# AGENT_SKILLS=
# Agent 技能路由策略：auto / manual
# AGENT_SKILL_ROUTING=auto
# Agent 技能自动权重
# AGENT_SKILL_AUTOWEIGHT=true
# Agent 记忆持久化
# AGENT_MEMORY_ENABLED=false
# Agent 风险审查
# AGENT_RISK_OVERRIDE=true

# === 3. 通知渠道密钥 (选填) ===

# 3a. 飞书机器人
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_WEBHOOK_URL=
# 飞书 Stream 模式（替代 Webhook）
# FEISHU_STREAM_ENABLED=false
# 飞书云文档 Folder Token
# FEISHU_FOLDER_TOKEN=
# 飞书消息最大字节
# FEISHU_MAX_BYTES=20000

# 3b. 企业微信
WECHAT_WEBHOOK_URL=
# 消息类型：markdown / text
# WECHAT_MSG_TYPE=markdown
# 消息最大字节
# WECHAT_MAX_BYTES=4000

# 3c. 邮件 SMTP
EMAIL_SENDER=
EMAIL_PASSWORD=
EMAIL_RECEIVERS=
# EMAIL_SENDER_NAME=股票分析助手

# 3d. Discord 机器人
# DISCORD_BOT_TOKEN=
# DISCORD_MAIN_CHANNEL_ID=
# DISCORD_WEBHOOK_URL=
# DISCORD_MAX_WORDS=2000

# 3e. Pushover
# PUSHOVER_USER_KEY=
# PUSHOVER_API_TOKEN=

# 3f. PushPlus
# PUSHPLUS_TOKEN=
# PUSHPLUS_TOPIC=

# 3i. ServerChan
# SERVERCHAN3_SENDKEY=

# 3j. 钉钉机器人
# DINGTALK_WEBHOOK_URL=
# DINGTALK_STREAM_ENABLED=false

# 3k. 自定义 Webhook
# CUSTOM_WEBHOOK_URLS=
# CUSTOM_WEBHOOK_BEARER_TOKEN=
# WEBHOOK_VERIFY_SSL=true

# === 4. 数据源配置 ===

# 4a. 富途牛牛 OpenAPI (选填，港股/美股实时行情)
# 需先安装启动 OpenD：https://openapi.futunn.com/futu-api-doc/intro/opend.html
FUTU_API_HOST=127.0.0.1
FUTU_API_PORT=11111
# FUTU_UNLOCK_PASSWORD=your_unlock_password

# 4b. TickFlow 实时行情 (选填)
# TICKFLOW_API_KEY=

# 4c. 东方财富连接补丁
# ENABLE_EASTMONEY_PATCH=false

# 4d. 实时行情配置
# 实时行情数据源优先级（逗号分隔）
# REALTIME_SOURCE_PRIORITY=tencent,akshare_sina,efinance,akshare_em
# 是否预取实时行情
# PREFETCH_REALTIME_QUOTES=true
# 实时行情缓存 TTL（秒）
# REALTIME_CACHE_TTL=600
# 是否启用实时行情
# ENABLE_REALTIME_QUOTE=true
# 是否启用实时技术指标
# ENABLE_REALTIME_TECHNICAL_INDICATORS=true
# 是否启用筹码分布
# ENABLE_CHIP_DISTRIBUTION=true

# === 5. 大盘与调度 ===
# 是否启用大盘复盘
# MARKET_REVIEW_ENABLED=true
# 大盘复盘市场：cn / hk / us
# MARKET_REVIEW_REGION=cn
# 是否校验交易日
# TRADING_DAY_CHECK_ENABLED=true
# 定时分析开关
# SCHEDULE_ENABLED=false
# 定时分析时间 (24h)
# SCHEDULE_TIME=18:00
# 启动时是否立即运行
# RUN_IMMEDIATELY=true
# SCHEDULE_RUN_IMMEDIATELY=true

# === 6. 报告与展示 ===
# 报告格式类型
# REPORT_TYPE=simple
# 是否仅生成摘要
# REPORT_SUMMARY_ONLY=false
# 是否合并邮件通知
# MERGE_EMAIL_NOTIFICATION=false
# 单股是否单独通知（与合并通知互斥）
# SINGLE_STOCK_NOTIFY=false
# 报告语言：zh / en
# REPORT_LANGUAGE=zh
# 报告模板目录
# REPORT_TEMPLATES_DIR=templates

# === 7. 数据库 ===
# DATABASE_PATH=./data/stock_analysis.db
# 启用 SQLite WAL 模式
# SQLITE_WAL_ENABLED=true
# SQLite 忙等待超时（毫秒）
# SQLITE_BUSY_TIMEOUT_MS=5000
# SQLite 写入重试次数
# SQLITE_WRITE_RETRY_MAX=3
# SQLite 写入重试初始延迟（秒）
# SQLITE_WRITE_RETRY_BASE_DELAY=0.1

# === 8. 本地环境设置 (通常保持默认) ===
LOG_DIR=./logs
ENV_FILE=.env
DEBUG=false
LOG_LEVEL=INFO
MAX_WORKERS=3
# 分析模式：simple / deep
# ANALYSIS_MODE=simple
# 新闻时效（天）
# NEWS_MAX_AGE_DAYS=3
# 新闻策略配置：short / normal / deep
# NEWS_STRATEGY_PROFILE=short
# 情绪偏差阈值
# BIAS_THRESHOLD=5.0
# 分析请求间延迟（秒）
# ANALYSIS_REQUEST_DELAY=2.0
# 报告完整性校验
# REPORT_INTEGRITY_ENABLED=true
# REPORT_INTEGRITY_RETRY=1
# 保存上下文快照
# SAVE_CONTEXT_SNAPSHOT=true
# 配置校验模式：warn / strict
# CONFIG_VALIDATE_MODE=warn
# 通知超时（秒）
# NOTIFICATION_TIMEOUT_SEC=15

# === 10. 其他 LLM Key (选填) ===
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_VISION_MODEL=
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# VISION_MODEL=
# VISION_PROVIDER_PRIORITY=gemini,anthropic,openai

# === 11. 代理 (选填) ===
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
