# =================================================================
# A股自选股智能分析系统 - 环境变量模板 (精简版)
# =================================================================
# 配置指引：
# 1. 业务参数 (如并发数、语言) ➜ 见 settings.yaml
# 2. 股票列表 (如代码、分组) ➜ 见 stocks.yaml
# 3. AI 模型路由 (如多 Key 轮询) ➜ 见 litellm_config.yaml
# =================================================================

# === 1. 核心敏感 Token (必填项) ===
GEMINI_API_KEY=your_gemini_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here
TUSHARE_TOKEN=your_tushare_token_here

# === 2. 搜索引擎 API Keys (选填，用于联网增强) ===
TAVILY_API_KEY=
SERPAPI_API_KEY=
BOCHA_API_KEY=
# OpenBB 公司新闻源（可选；需本地安装 openbb 及对应 provider 扩展）
OPENBB_NEWS_ENABLED=false
OPENBB_NEWS_PROVIDER=yfinance
# OpenBB 行情/日线数据源（可选；需本地安装 openbb 及对应 provider 扩展）
OPENBB_FETCHER_ENABLED=false
OPENBB_FETCHER_PROVIDER=yfinance

# === 2b. Agent 分析（选填） ===
# AGENT_MODE=true 会强制单股分析和策略问股走 Agent
AGENT_MODE=false
# 条件式过 Agent：经典单股分析仍是默认，但在数据缺口、密集/高风险情报等复杂场景自动升级为 Agent
AGENT_AUTO_ROUTE_ANALYSIS=false
# Agent 专用主模型（留空继承 LITELLM_MODEL）
AGENT_LITELLM_MODEL=

# === 3. 通知渠道密钥 (选填) ===
# 飞书机器人
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_WEBHOOK_URL=

# 企业微信
WECHAT_WEBHOOK_URL=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 邮件 SMTP
EMAIL_SENDER=
EMAIL_PASSWORD=
EMAIL_RECEIVERS=

# === 4. 本地环境设置 (通常保持默认) ===
DATABASE_PATH=./data/stock_analysis.db
LOG_DIR=./logs
ENV_FILE=.env
REPORT_TEMPLATES_DIR=templates
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
