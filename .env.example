# =================================================================
# A股自选股智能分析系统 - 环境变量模板 (精简版)
# =================================================================
# 配置指引：
# 1. 业务参数 (如并发数、语言) ➜ 见 settings.yaml
# 2. 股票列表 (如代码、分组) ➜ 见 stocks.yaml
# 3. AI 模型路由 (如多 Key 轮询) ➜ 见 litellm_config.yaml
# =================================================================

# === 1. 核心敏感 Token (必填项) ===
GEMINI_API_KEY=your_gemini_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here
TUSHARE_TOKEN=your_tushare_token_here

# === 2. 搜索引擎 API Keys (选填，用于联网增强) ===
TAVILY_API_KEY=
SERPAPI_API_KEY=
BOCHA_API_KEY=

# === 3. 通知渠道密钥 (选填) ===
# 飞书机器人
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_WEBHOOK_URL=

# 企业微信
WECHAT_WEBHOOK_URL=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 邮件 SMTP
EMAIL_SENDER=
EMAIL_PASSWORD=
EMAIL_RECEIVERS=

# === 4. 本地环境设置 (通常保持默认) ===
DATABASE_PATH=./data/stock_analysis.db
LOG_DIR=./logs
ENV_FILE=.env
REPORT_TEMPLATES_DIR=templates
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
